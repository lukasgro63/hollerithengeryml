# ============================================================================
# HollerithEnergyML — environment variables (example)
#
# Copy this file to `.env` and fill in real values for your environment.
# NEVER commit real `.env` files to git.
# ============================================================================

# Runtime environment (development | production)
ENVIRONMENT=development

# Logging level (debug | info | warning | error)
LOG_LEVEL=info

# --- Backend (apps/api) -----------------------------------------------------
# Comma-separated list of origins allowed to call the API.
# Development: http://localhost:3000
# Production:  https://hollerith.example.de
ALLOWED_ORIGINS=http://localhost:3000

# Rate limit on /api/v1/predictions (requests per minute per client IP)
PREDICTIONS_RATE_LIMIT_PER_MINUTE=30

# --- Frontend (apps/web) ----------------------------------------------------
# Public URL where the backend API is reachable from the browser.
NEXT_PUBLIC_API_URL=http://localhost:8000
