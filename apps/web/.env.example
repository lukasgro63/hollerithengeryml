# ============================================================================
# apps/web — public environment variables
#
# Copy to `.env.local` for local development. Values prefixed with
# NEXT_PUBLIC_ are baked into the client bundle at build time and
# exposed to the browser.
# ============================================================================

# Base URL of the HollerithEnergyML backend API.
# Local dev: http://localhost:8000
# Docker compose (internal): http://api:8000
# Production (through Caddy): https://hollerith.example.de
NEXT_PUBLIC_API_URL=http://localhost:8000

# Canonical base URL of the site (used for metadata, sitemap.xml,
# robots.txt, and OpenGraph URLs).
# Local dev can leave this unset; the default placeholder is safe.
NEXT_PUBLIC_SITE_URL=https://hollerith.example.de
